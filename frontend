import pandas as pd
import numpy as np
from sklearn.preprocessing import MinMaxScaler
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import LSTM, Dense, Dropout
import matplotlib.pyplot as plt

# 1. LOAD & CLEAN
df = pd.read_csv('silver_prices_data.csv')
df['Date'] = pd.to_datetime(df['Date'])
df = df.sort_values('Date')

# 2. FEATURE ENGINEERING (Super Gold)
# RSI (Momentum)
delta = df['Close'].diff()
gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()
loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()
df['RSI'] = 100 - (100 / (1 + (gain / loss)))

# MACD (Trend)
df['MACD'] = df['Close'].ewm(span=12).mean() - df['Close'].ewm(span=26).mean()

# Bollinger Bands (Volatility)
df['MA20'] = df['Close'].rolling(window=20).mean()
df['Upper'] = df['MA20'] + (df['Close'].rolling(window=20).std() * 2)
df['Lower'] = df['MA20'] - (df['Close'].rolling(window=20).std() * 2)

# Lags & Target
df['Lag_1'] = df['Close'].shift(1)
df['Target'] = df['Close'].shift(-1)
df = df.dropna().reset_index(drop=True)

# 3. PREPARE FOR LSTM
features = ['Close', 'Open', 'High', 'Low', 'Volume', 'RSI', 'MACD', 'Upper', 'Lower', 'Lag_1']
scaler = MinMaxScaler()
scaled_data = scaler.fit_transform(df[features + ['Target']])

X, y = [], []
window = 30 # Use 30 days to predict the 31st
for i in range(window, len(scaled_data)):
    X.append(scaled_data[i-window:i, :-1])
    y.append(scaled_data[i, -1])

X, y = np.array(X), np.array(y)
split = int(len(X) * 0.8)
X_train, X_test, y_train, y_test = X[:split], X[split:], y[:split], y[split:]

# 4. BUILD & TRAIN LSTM
model = Sequential([
    LSTM(50, return_sequences=True, input_shape=(X.shape[1], X.shape[2])),
    Dropout(0.2),
    LSTM(50),
    Dropout(0.2),
    Dense(1)
])
model.compile(optimizer='adam', loss='mse')
model.fit(X_train, y_train, epochs=20, batch_size=32, verbose=0)

# 5. RESULTS
preds = model.predict(X_test)
